# --- AION-FSCM DETERMINISTIC SHIELD ---

# 1. System Backups & Environment (Core IP Protection)
.env
*.tar.gz
*.zip
*.bin
*.iso
/storage/*
/backup/*
/quarantine/*

# 2. Build Artifacts & EDA Tools (State Cleanup)
/build/
/bin/
/obj/
/output/
*.log
*.tmp
*.bak

# 3. Local Configurations & IDE Noise (Entropy Prevention)
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# 4. Documentation Artifacts
# Allow only finalized proofs, suppress raw experimental noise
docs/evidence/raw_data/
!docs/evidence/README.md

# 5. Lock Files (Elimination of Dependency Drift)
# Strict versioning via static architecture; no dynamic dependency tracking
package-lock.json
yarn.lock
poetry.lock
