# --- AION-FSCM DETERMINISTIC SHIELD ---

# 1. System-Backups & Umgebung (Schutz der AION-Kerne)
.env
*.tar.gz
*.zip
*.bin
*.iso
/storage/*
/backup/*
/quarantine/*

# 2. Build-Artefakte & EDA-Tools
/build/
/bin/
/obj/
/output/
*.log
*.tmp
*.bak

# 3. Lokale Konfigurationen & IDE-Noise
.vscode/
.idea/
*.swp
.DS_Store

# 4. Dokumentations-Artefakte
# Nur finale Beweise zulassen, kein experimentelles Rauschen
docs/evidence/raw_data/
!docs/evidence/README.md

# 5. Lock-Files (Vermeidung von Dependency-Drift)
# Wir nutzen keine instabilen Dependencies
package-lock.json
yarn.lock
poetry.lock
